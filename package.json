{
	"name": "lc-stats-svelte",
	"version": "0.0.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/xdnw/lc_stats_svelte.git"
	},
	"private": true,
	"engines": {
		"node": "^20.19.0 || ^22.12.0 || >=24.0.0",
		"npm": ">=10"
	},
	"packageManager": "npm@10.9.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prod": "npm run build && npm run preview -- --port 5173",
		"test": "vitest run",
		"verify:navigation": "node ./scripts/verifyNavigation.mjs",
		"verify:navigation:perf": "node ./scripts/verifyNavigation.mjs --report-perf",
		"lighthouse:matrix": "node ./scripts/runLighthouseMatrix.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "gh-pages -d build --repo https://github.com/xdnw/lc_stats_svelte.git"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@vitejs/plugin-legacy": "^8.0.1",
		"chrome-launcher": "^1.2.1",
		"gh-pages": "^6.3.0",
		"jsdom": "^28.1.0",
		"lighthouse": "^12.8.2",
		"playwright": "^1.59.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"terser": "^5.46.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"type": "module",
	"dependencies": {
		"@types/d3": "^7.4.3",
		"d3": "^7.9.0",
		"lz-string": "^1.5.0",
		"msgpackr": "^1.11.9"
	}
}
